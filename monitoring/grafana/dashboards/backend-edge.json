{
 "uid": "oncall-backend",
 "title": "OnCall \u2014 Backend (Edge View)",
 "tags": [
  "oncall",
  "backend"
 ],
 "schemaVersion": 39,
 "version": 1,
 "editable": true,
 "timezone": "browser",
 "time": {
  "from": "now-6h",
  "to": "now"
 },
 "refresh": "30s",
 "panels": [
  {
   "title": "Requests/sec (edge)",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 0,
    "y": 0,
    "w": 12,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {
     "unit": "reqps"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "rate(nginx_http_requests_total[5m])",
     "refId": "A",
     "legendFormat": ""
    }
   ]
  },
  {
   "title": "Backend /health latency (p=probe)",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 12,
    "y": 0,
    "w": 12,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {
     "unit": "s"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "probe_duration_seconds{job=\"backend-health\"}",
     "refId": "A",
     "legendFormat": ""
    }
   ]
  },
  {
   "title": "Backend up",
   "type": "stat",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 0,
    "y": 8,
    "w": 6,
    "h": 4
   },
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "green",
        "value": 1
       }
      ]
     }
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "probe_success{job=\"backend-health\"}",
     "refId": "A",
     "legendFormat": ""
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "title": "HTTP status of /health probe",
   "type": "stat",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 6,
    "y": 8,
    "w": 6,
    "h": 4
   },
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "green",
        "value": 1
       }
      ]
     }
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "probe_http_status_code{job=\"backend-health\"}",
     "refId": "A",
     "legendFormat": ""
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "title": "Backend container CPU",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 0,
    "y": 12,
    "w": 12,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {
     "unit": "percent"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "rate(container_cpu_usage_seconds_total{name=\"oncall-backend\"}[5m])*100",
     "refId": "A",
     "legendFormat": ""
    }
   ]
  },
  {
   "title": "Backend container memory",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 12,
    "y": 12,
    "w": 12,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {
     "unit": "bytes"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "container_memory_usage_bytes{name=\"oncall-backend\"}",
     "refId": "A",
     "legendFormat": ""
    }
   ]
  },
  {
   "title": "Active users / drivers / rides / scooters",
   "type": "text",
   "gridPos": {
    "x": 12,
    "y": 8,
    "w": 12,
    "h": 4
   },
   "options": {
    "mode": "markdown",
    "content": "**Pending backlog M-5:** these business metrics require a native `/metrics` endpoint in the backend (admin-JWT `/admin/metrics` exists but is not scrapeable). Approval-gated app change \u2014 no code was modified in P7-04."
   }
  }
 ]
}