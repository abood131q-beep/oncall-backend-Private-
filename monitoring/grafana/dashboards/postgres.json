{
 "uid": "oncall-postgres",
 "title": "OnCall \u2014 PostgreSQL",
 "tags": [
  "oncall",
  "postgres"
 ],
 "schemaVersion": 39,
 "version": 1,
 "editable": true,
 "timezone": "browser",
 "time": {
  "from": "now-6h",
  "to": "now"
 },
 "refresh": "30s",
 "panels": [
  {
   "title": "Up",
   "type": "stat",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 0,
    "y": 0,
    "w": 4,
    "h": 4
   },
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "green",
        "value": 1
       }
      ]
     }
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "pg_up",
     "refId": "A",
     "legendFormat": ""
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "title": "Connections",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 4,
    "y": 0,
    "w": 10,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {},
    "overrides": []
   },
   "targets": [
    {
     "expr": "pg_stat_database_numbackends{datname=\"oncall\"}",
     "refId": "A",
     "legendFormat": ""
    }
   ]
  },
  {
   "title": "Transactions/sec",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 14,
    "y": 0,
    "w": 10,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {},
    "overrides": []
   },
   "targets": [
    {
     "expr": "rate(pg_stat_database_xact_commit{datname=\"oncall\"}[5m])",
     "refId": "A",
     "legendFormat": "commit"
    },
    {
     "expr": "rate(pg_stat_database_xact_rollback{datname=\"oncall\"}[5m])",
     "refId": "B",
     "legendFormat": "rollback"
    }
   ]
  },
  {
   "title": "Rows fetched/returned",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 0,
    "y": 8,
    "w": 12,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {},
    "overrides": []
   },
   "targets": [
    {
     "expr": "rate(pg_stat_database_tup_fetched{datname=\"oncall\"}[5m])",
     "refId": "A",
     "legendFormat": ""
    },
    {
     "expr": "rate(pg_stat_database_tup_returned{datname=\"oncall\"}[5m])",
     "refId": "B",
     "legendFormat": ""
    }
   ]
  },
  {
   "title": "Slow/long-running (max tx duration)",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 12,
    "y": 8,
    "w": 12,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {
     "unit": "s"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "pg_stat_activity_max_tx_duration{datname=\"oncall\"}",
     "refId": "A",
     "legendFormat": ""
    }
   ]
  }
 ]
}