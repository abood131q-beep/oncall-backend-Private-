{
 "uid": "oncall-nginx",
 "title": "OnCall \u2014 Nginx Edge",
 "tags": [
  "oncall",
  "nginx"
 ],
 "schemaVersion": 39,
 "version": 1,
 "editable": true,
 "timezone": "browser",
 "time": {
  "from": "now-6h",
  "to": "now"
 },
 "refresh": "30s",
 "panels": [
  {
   "title": "Up",
   "type": "stat",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 0,
    "y": 0,
    "w": 4,
    "h": 4
   },
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "green",
        "value": 1
       }
      ]
     }
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "nginx_up",
     "refId": "A",
     "legendFormat": ""
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "title": "Requests/sec",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 4,
    "y": 0,
    "w": 10,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {
     "unit": "reqps"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "rate(nginx_http_requests_total[5m])",
     "refId": "A",
     "legendFormat": ""
    }
   ]
  },
  {
   "title": "Active connections",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 14,
    "y": 0,
    "w": 10,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {},
    "overrides": []
   },
   "targets": [
    {
     "expr": "nginx_connections_active",
     "refId": "A",
     "legendFormat": ""
    }
   ]
  },
  {
   "title": "Conn states",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 0,
    "y": 8,
    "w": 12,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {},
    "overrides": []
   },
   "targets": [
    {
     "expr": "nginx_connections_reading",
     "refId": "A",
     "legendFormat": "reading"
    },
    {
     "expr": "nginx_connections_writing",
     "refId": "B",
     "legendFormat": "writing"
    },
    {
     "expr": "nginx_connections_waiting",
     "refId": "C",
     "legendFormat": "waiting"
    }
   ]
  },
  {
   "title": "Accepted vs handled",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 12,
    "y": 8,
    "w": 12,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {},
    "overrides": []
   },
   "targets": [
    {
     "expr": "rate(nginx_connections_accepted[5m])",
     "refId": "A",
     "legendFormat": "accepted"
    },
    {
     "expr": "rate(nginx_connections_handled[5m])",
     "refId": "B",
     "legendFormat": "handled"
    }
   ]
  },
  {
   "title": "TLS usage",
   "type": "text",
   "gridPos": {
    "x": 0,
    "y": 16,
    "w": 24,
    "h": 3
   },
   "options": {
    "mode": "markdown",
    "content": "TLS handshake/version breakdown is not exposed by stub_status. Cert expiry is tracked on the Health dashboard (blackbox). Per-version TLS metrics require the nginx VTS module or log-based metrics \u2014 candidate for the Loki profile."
   }
  }
 ]
}