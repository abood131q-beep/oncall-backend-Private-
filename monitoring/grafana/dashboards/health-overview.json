{
 "uid": "oncall-health",
 "title": "OnCall \u2014 Platform Health",
 "tags": [
  "oncall",
  "health"
 ],
 "schemaVersion": 39,
 "version": 1,
 "editable": true,
 "timezone": "browser",
 "time": {
  "from": "now-6h",
  "to": "now"
 },
 "refresh": "30s",
 "panels": [
  {
   "title": "Backend /health",
   "type": "stat",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 0,
    "y": 0,
    "w": 4,
    "h": 4
   },
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "green",
        "value": 1
       }
      ]
     }
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "probe_success{job=\"backend-health\"}",
     "refId": "A",
     "legendFormat": ""
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "title": "PostgreSQL",
   "type": "stat",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 4,
    "y": 0,
    "w": 4,
    "h": 4
   },
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "green",
        "value": 1
       }
      ]
     }
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "pg_up",
     "refId": "A",
     "legendFormat": ""
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "title": "Redis",
   "type": "stat",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 8,
    "y": 0,
    "w": 4,
    "h": 4
   },
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "green",
        "value": 1
       }
      ]
     }
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "redis_up",
     "refId": "A",
     "legendFormat": ""
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "title": "Nginx",
   "type": "stat",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 12,
    "y": 0,
    "w": 4,
    "h": 4
   },
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "green",
        "value": 1
       }
      ]
     }
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "nginx_up",
     "refId": "A",
     "legendFormat": ""
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "title": "TLS days left",
   "type": "stat",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 16,
    "y": 0,
    "w": 4,
    "h": 4
   },
   "fieldConfig": {
    "defaults": {
     "unit": "d",
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "green",
        "value": 1
       }
      ]
     }
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "(probe_ssl_earliest_cert_expiry{job=\"tls-cert\"} - time())/86400",
     "refId": "A",
     "legendFormat": ""
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "title": "Containers running",
   "type": "stat",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 20,
    "y": 0,
    "w": 4,
    "h": 4
   },
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "green",
        "value": 1
       }
      ]
     }
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "count(container_last_seen{name=~\"oncall.*\"})",
     "refId": "A",
     "legendFormat": ""
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "title": "Backend /health latency",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 0,
    "y": 4,
    "w": 12,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {
     "unit": "s"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "probe_duration_seconds{job=\"backend-health\"}",
     "refId": "A",
     "legendFormat": ""
    }
   ]
  },
  {
   "title": "Container status (cAdvisor)",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 12,
    "y": 4,
    "w": 12,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {
     "unit": "bytes"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "container_memory_usage_bytes{name=~\"oncall.*\"}",
     "refId": "A",
     "legendFormat": "{{name}}"
    }
   ]
  }
 ]
}