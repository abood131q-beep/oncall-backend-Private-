{
 "uid": "oncall-redis",
 "title": "OnCall \u2014 Redis",
 "tags": [
  "oncall",
  "redis"
 ],
 "schemaVersion": 39,
 "version": 1,
 "editable": true,
 "timezone": "browser",
 "time": {
  "from": "now-6h",
  "to": "now"
 },
 "refresh": "30s",
 "panels": [
  {
   "title": "Up",
   "type": "stat",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 0,
    "y": 0,
    "w": 4,
    "h": 4
   },
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "green",
        "value": 1
       }
      ]
     }
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "redis_up",
     "refId": "A",
     "legendFormat": ""
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "title": "Memory used",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 4,
    "y": 0,
    "w": 10,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {
     "unit": "bytes"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "redis_memory_used_bytes",
     "refId": "A",
     "legendFormat": "used"
    },
    {
     "expr": "redis_memory_max_bytes",
     "refId": "B",
     "legendFormat": "max"
    }
   ]
  },
  {
   "title": "Keys",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 14,
    "y": 0,
    "w": 10,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {},
    "overrides": []
   },
   "targets": [
    {
     "expr": "sum(redis_db_keys)",
     "refId": "A",
     "legendFormat": ""
    }
   ]
  },
  {
   "title": "Connected clients",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 0,
    "y": 8,
    "w": 12,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {},
    "overrides": []
   },
   "targets": [
    {
     "expr": "redis_connected_clients",
     "refId": "A",
     "legendFormat": ""
    }
   ]
  },
  {
   "title": "Ops/sec",
   "type": "timeseries",
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus"
   },
   "gridPos": {
    "x": 12,
    "y": 8,
    "w": 12,
    "h": 8
   },
   "fieldConfig": {
    "defaults": {
     "unit": "ops"
    },
    "overrides": []
   },
   "targets": [
    {
     "expr": "rate(redis_commands_processed_total[5m])",
     "refId": "A",
     "legendFormat": ""
    }
   ]
  }
 ]
}