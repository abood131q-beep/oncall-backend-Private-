{
  "name": "oncall-backend",
  "version": "1.0.0",
  "description": "OnCall ride-sharing & scooter backend — Kuwait",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "bash run_tests.sh",
    "test:unit": "node --test --test-timeout=60000 tests/unit/*.test.js",
    "test:ab": "node scripts/run-ab.mjs",
    "test:coverage": "node --experimental-test-coverage --test tests/unit/*.test.js",
    "verify:shadow": "node scripts/verify-shadow.mjs",
    "migrate": "node scripts/migrate.js",
    "verify:pg": "bash scripts/verify-postgres.sh",
    "lint": "eslint 'src/**/*.js' server.js database.js --max-warnings 0",
    "lint:fix": "eslint 'src/**/*.js' server.js database.js --fix",
    "format": "prettier --write 'src/**/*.js' server.js database.js",
    "format:check": "prettier --check 'src/**/*.js' server.js database.js",
    "ci": "npm run lint && npm run format:check && npm run test:unit && npm run test:ab",
    "verify:identity-shadow": "node scripts/verify-identity-shadow.mjs",
    "identity:parity-report": "node scripts/identity-parity-report.mjs",
    "identity:gate-b2": "node scripts/identity-gate-b2.mjs",
    "identity:rollback-drill": "node scripts/identity-rollback-drill.mjs",
    "identity:cross-replica": "node tests/integration/identity-cross-replica-revocation.mjs",
    "identity:db-parity": "node -r ./tools/dev/sqlite3-compat.js scripts/identity-db-parity.mjs"
  },
  "keywords": [
    "oncall",
    "ride-sharing",
    "kuwait",
    "backend"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "pg": "^8.22.0",
    "socket.io": "^4.8.3",
    "sqlite3": "^6.0.1"
  }
}
