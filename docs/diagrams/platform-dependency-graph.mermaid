  config --> resources
  config --> lifecycle
  config --> compatibility
  config --> extensions
  policy --> extensions

  %% port-injection edges (dependency service injected as `ports`)
  identity -. port .-> gateway
  policy -. port .-> gateway
  ratelimit -. port .-> gateway
  features -. port .-> gateway
  discovery -. port .-> gateway
  identity -. port .-> mesh
  policy -. port .-> mesh
  resilience -. port .-> mesh
  ratelimit -. port .-> mesh
  discovery -. port .-> mesh

  classDef edge fill:#eef,stroke:#66a;
  class gateway,mesh edge;
