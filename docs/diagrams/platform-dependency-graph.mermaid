  backbone --> config
  config --> storage
  config --> lock
  config --> identity
  storage --> identity
  config --> policy
  identity --> policy
  config --> features
  storage --> features
  config --> messaging
  config --> workflow
  messaging --> workflow
  lock --> workflow
  storage --> workflow
  config --> audit
