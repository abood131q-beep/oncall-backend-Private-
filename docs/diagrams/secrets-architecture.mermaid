flowchart TB
  subgraph Consumers["Consumers (via port only)"]
    SVC["Platform Services / Kernels"]
    EXT["Extensions (SDK · ADR-018)"]
  end

  subgraph SK["Secrets Kernel Service — ADR-028"]
    SERVICE["secretsService\nstore/resolve/rotate\ndelete/list/health"]
    METRICS["metrics (Prometheus)"]
    ADAPTER["sdkAdapter\nnamespace-scoped secrets() port\nsecrets:read · secrets:write"]
  end

  subgraph Domain["Domain (pure)"]
    SEC["secret (versioned · protected value · checksum)"]
    POL["rotationPolicy (isDue)"]
    RED["redaction (constant mask)"]
    ERR["errors"]
    EVT["events (catalog)"]
  end

  subgraph Providers["Provider adapters (persistence only)"]
    MEM["memory (current + version history)"]
    FUT["extension points:\nvault · aws-secrets-manager · azure-key-vault · gcp-secret-manager · custom"]
  end

  BACKBONE["Event Backbone (ADR-016)\nEventPublisher port"]
  POLICY["Policy Engine (ADR-025)\ngoverns secrets:read/write"]
  AUDIT["Audit Platform (ADR-026)\nrecords secret events"]

  SVC --> SERVICE
  EXT -->|this.secrets| ADAPTER --> SERVICE
  SERVICE --> Domain
  SERVICE --> Providers
  SERVICE -->|SecretStored/Resolved/Rotated/Deleted| BACKBONE
  BACKBONE -.-> AUDIT
  POLICY -.->|authorize| ADAPTER
  SERVICE --> METRICS

  classDef kernel fill:#eef,stroke:#66a;
  class SERVICE,METRICS,ADAPTER kernel;
