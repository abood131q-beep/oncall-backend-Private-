# OnCall Backend — Environment Variables Template
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية
# cp .env.example .env
#
# المتغيرات المُعلَّق عليها بـ # هي اختيارية — فعّلها عند الحاجة.
# المتغيرات غير المُعلَّق عليها إما إلزامية أو لها قيمة افتراضية مناسبة.

# ─── Core ─────────────────────────────────────────────────────────────────────

# بيئة التشغيل: development | production
# تُفعّل production Safety Guards عند ضبطها على production
NODE_ENV=development

# منفذ HTTP للسيرفر
PORT=3000

# سر JWT — 64 حرف عشوائي على الأقل (إلزامي، السيرفر يتوقف بدونه)
# لإنشاء قيمة آمنة: openssl rand -hex 32
JWT_SECRET=change_this_to_a_random_64_char_hex_string

# ─── Admin ────────────────────────────────────────────────────────────────────

# أرقام هاتف المديرين مفصولة بفاصلة (بدون مسافات)
# مثال: 96599999999,96598888888
ADMIN_PHONES=96599999999

# ─── Database ─────────────────────────────────────────────────────────────────

# مسار ملف SQLite (افتراضي: ./oncall.db — في مجلد تشغيل السيرفر)
# في الإنتاج يُفضَّل مسار مطلق: DB_PATH=/var/lib/oncall/oncall.db
# DB_PATH=./oncall.db

# ─── Google Maps ──────────────────────────────────────────────────────────────

# مطلوب لـ Places Autocomplete وPlace Details
# احصل عليه من: https://console.cloud.google.com → APIs & Services → Credentials
# فعّل: Places API (New) أو Places API
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ─── OTP / SMS ────────────────────────────────────────────────────────────────

# false (default): تسجيل الدخول بدون OTP — للتطوير والاختبار فقط
# true:            يُلزم OTP عند كل تسجيل دخول — إلزامي في الإنتاج
REQUIRE_OTP=false

# SMS_PROVIDER: كيفية إرسال OTP
#   console   (default) — يطبع الكود في السجل فقط (dev/testing)
#   unifonic             — Unifonic REST API (الكويت / GCC)  https://unifonic.com
#   twilio               — Twilio REST API (دولي)            https://twilio.com
SMS_PROVIDER=console

# ── Unifonic ──────────────────────────────────────────────────────────────────
# SMS_API_KEY   = App SID  (من Unifonic Console → My Apps)
# SMS_FROM      = Sender ID المعتمد (e.g. OnCall)
# SMS_API_KEY=YOUR_UNIFONIC_APP_SID
# SMS_FROM=OnCall

# ── Twilio ────────────────────────────────────────────────────────────────────
# SMS_ACCOUNT_SID = Account SID (من Twilio Console)
# SMS_API_KEY     = Auth Token  (من Twilio Console)
# SMS_FROM        = رقم Twilio الدولي (e.g. +14155552671)
# SMS_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SMS_API_KEY=your_twilio_auth_token
# SMS_FROM=+14155552671

# ─── Firebase / Push Notifications ───────────────────────────────────────────

# Service Account JSON كاملاً (في سطر واحد) أو base64-encoded
# احصل عليه من: https://console.firebase.google.com → Project Settings → Service Accounts
# لتحويله إلى base64: cat service-account.json | base64 | tr -d '\n'
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Firebase Project ID (اختياري — يُقرأ تلقائياً من service account JSON)
# FIREBASE_PROJECT_ID=your-firebase-project-id

# ─── Payment Gateway ──────────────────────────────────────────────────────────

# false: POST /wallet/charge يُرجع 503 (لا gateway — بيئة تطوير)
# true:  يُفعَّل بعد ربط بوابة دفع حقيقية (K-Net / Visa / Apple Pay / MyFatoorah)
# خطوات التفعيل:
#   1. أضف PAYMENT_GATEWAY_URL و PAYMENT_GATEWAY_KEY
#   2. نفّذ payment intent → webhook → credit wallet في /wallet/charge handler
#   3. اضبط PAYMENT_ENABLED=true
PAYMENT_ENABLED=false
# PAYMENT_GATEWAY_URL=https://api.myfatoorah.com
# PAYMENT_GATEWAY_KEY=YOUR_GATEWAY_API_KEY

# ─── Network / CORS ───────────────────────────────────────────────────────────

# HTTP CORS: نطاقات الإنتاج المسموح بها (فصل بفاصلة)
# في التطوير: اتركه فارغاً — localhost مسموح دائماً.
# في الإنتاج (للوحات إدارة ويب): ALLOWED_ORIGINS=https://admin.oncall.app
# Flutter Mobile لا يتأثر (لا يُرسل Origin header).
# ALLOWED_ORIGINS=https://admin.oncall.app,https://dashboard.oncall.app

# WebSocket CORS: نطاق مسموح لاتصالات Socket.IO
# '*' مقبول للـ Flutter Mobile (لا origin في mobile clients).
# للوحات ويب في الإنتاج: SOCKET_CORS_ORIGIN=https://your-dashboard.com
# SOCKET_CORS_ORIGIN=*

# ─── Logging ──────────────────────────────────────────────────────────────────

# مستوى التسجيل: DEBUG | INFO | WARN | ERROR
# DEBUG  — جميع الرسائل (مطوّل جداً — للتطوير فقط)
# INFO   — رسائل تشغيلية + تحذيرات + أخطاء (الافتراضي)
# WARN   — تحذيرات وأخطاء فقط (موصى به في الإنتاج)
# ERROR  — أخطاء فقط (الحد الأدنى)
# LOG_LEVEL=INFO

# ─── System ───────────────────────────────────────────────────────────────────

# Timezone لعرض الأوقات في Admin Dashboard
# مثال: Asia/Kuwait | UTC | America/New_York
# TZ=Asia/Kuwait
